#!/usr/bin/env bash

set -e

# 프로젝트 루트 기준 경로 계산
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# NIM_DIR="$PROJECT_DIR"
PORT=8082

# 1) NIM 프록시(server.py)가 안 떠 있으면 백그라운드로 실행
if ! lsof -i ":${PORT}" >/dev/null 2>&1; then
  echo "[agent] NIM proxy를 ${PORT} 포트에서 시작합니다..."
  # cd "$NIM_DIR"
  # 가상환경 활성화 후 서버를 백그라운드로 실행
  # 로그는 nim-proxy/server.log 에 남김
  bash -lc "source .venv/bin/activate && python server.py >> server.log 2>&1" &
  sleep 2
else
  echo "[agent] 이미 ${PORT} 포트에서 NIM proxy가 실행 중입니다."
fi

# 2) Claude Code 실행 (NIM 프록시를 Anthropic API처럼 사용)
cd "$PROJECT_DIR"
echo "[agent] Claude Code를 NIM 프록시(http://localhost:${PORT})에 연결해서 실행합니다."
export ANTHROPIC_BASE_URL="http://localhost:${PORT}"
export ANTHROPIC_AUTH_TOKEN="dummy"

exec claude "$@"

